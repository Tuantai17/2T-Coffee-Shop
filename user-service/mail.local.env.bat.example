@echo off
REM Sao chep file nay thanh: mail.local.env.bat
REM Sau do dien App Password moi cua Gmail vao ben duoi.

set "MAIL_HOST=smtp.gmail.com"
set "MAIL_PORT=587"
set "MAIL_USERNAME=your_gmail@gmail.com"
set "MAIL_PASSWORD=your_16_char_app_password"
set "MAIL_SMTP_AUTH=true"
set "MAIL_SMTP_STARTTLS=true"
set "APP_PASSWORD_RESET_EXPOSE_DEV_OTP=false"
