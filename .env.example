# Database Credentials
DB_USERNAME=postgres
DB_PASSWORD=secret_postgres_password

# JWT
JWT_SECRET=9a4f2c8d3b7a1e5f8g9h0i1j2k3l4m5n6o7p8q9r0s1t2u3v4w5x6y7z8a9b0c1d

# Eureka
EUREKA_CLIENT_SERVICEURL_DEFAULTZONE=http://eureka-server:8761/eureka

# Postgres Database URL (used by services internally)
SPRING_DATASOURCE_URL_USER=jdbc:postgresql://postgres:5432/user_db
SPRING_DATASOURCE_URL_CATALOG=jdbc:postgresql://postgres:5432/catalog_db
SPRING_DATASOURCE_URL_ORDER=jdbc:postgresql://postgres:5432/order_db
SPRING_DATASOURCE_URL_INVENTORY=jdbc:postgresql://postgres:5432/inventory_db
SPRING_DATASOURCE_URL_PAYMENT=jdbc:postgresql://postgres:5432/payment_db
SPRING_DATASOURCE_URL_DELIVERY=jdbc:postgresql://postgres:5432/delivery_db
SPRING_DATASOURCE_URL_LOYALTY=jdbc:postgresql://postgres:5432/loyalty_db
SPRING_DATASOURCE_URL_MINI_GAME=jdbc:postgresql://postgres:5432/game_db
SPRING_DATASOURCE_URL_REVENUE=jdbc:postgresql://postgres:5432/revenue_db
SPRING_DATASOURCE_URL_RECOMMENDATION=jdbc:postgresql://postgres:5432/recommendation_db

# MongoDB (Notification Service)
SPRING_DATA_MONGODB_URI=mongodb://mongodb:27017/notification_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# VNPAY Sandbox configuration
VNPAY_TMN_CODE=XTMJXUHE
VNPAY_HASH_SECRET=DÁN_SECRET_KEY_CỦA_BẠN_VÀO_ĐÂY
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_VERSION=2.1.0
VNPAY_COMMAND=pay
VNPAY_ORDER_TYPE=other
VNPAY_LOCALE=vn

# Replace <BACKEND_PUBLIC_DOMAIN> with your ngrok url
VNPAY_RETURN_URL=https://<BACKEND_PUBLIC_DOMAIN>/api/payments/vnpay/return
VNPAY_IPN_URL=https://<BACKEND_PUBLIC_DOMAIN>/api/payments/vnpay/ipn

# Frontend URL
FRONTEND_PUBLIC_URL=http://localhost:5173

# Cấu hình Gmail
MAIL_ENABLED=true
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-google-app-password
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true
MAIL_FROM_NAME=BrewMoments
MAIL_REPLY_TO=your-email@gmail.com
APP_FRONTEND_URL=http://localhost:5173
APP_TIME_ZONE=Asia/Ho_Chi_Minh
